{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "nextjs",
    "buildCommand": "bun run build",
    "installCommand": "bun install",
    "git": {
        "deploymentEnabled": {
            "main": true
        }
    },
    "crons": [
        {
            "path": "/api/cron/cleanup-logs",
            "schedule": "0 3 * * *"
        }
    ]
}
