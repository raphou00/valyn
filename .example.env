NODE_ENV=development
APP_URL=http://localhost:3000

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=x
AWS_SECRET_ACCESS_KEY=x

RATE_LIMITS_TABLE_NAME=x

DATABASE_URL=postgres://raphaelrey@localhost:5432/raphaelrey

# Shopify app credentials (Partners dashboard)
SHOPIFY_API_KEY=x
SHOPIFY_API_SECRET=x
SHOPIFY_SCOPES=read_orders,read_fulfillments,read_customers
SHOPIFY_APP_URL=http://localhost:3000

# SES inbound (email intake) — set after `pulumi up`
INBOUND_EMAIL_BUCKET=x
INBOUND_EMAIL_DOMAIN=inbound.example.com
INBOUND_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:valyn-inbound-dev

# Encryption key for SMTP creds at rest (32-byte base64)
SMTP_CREDS_KEY=x

# WISMO LLM classifier (Bedrock). Optional — falls back to keyword
# classifier if unset or if model access isn't enabled in the region.
# Enable model access for BEDROCK_MODEL_ID in the AWS Bedrock console.
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0
WISMO_LLM_ENABLED=true
