{
    "name": "valyn",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "prepare": "husky || true",
        "postinstall": "prisma generate",
        "dev": "next dev",
        "build": "prisma generate && next build",
        "start": "next start",
        "type-check": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint",
        "fmt:write": "prettier --write \"**/*.{ts,tsx,mdx,json}\" --cache",
        "fmt:check": "prettier --check \"**/*.{ts,tsx,mdx,json}\" --cache",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:studio": "prisma studio",
        "db:seed": "prisma db seed",
        "deploy": "cd aws && pulumi login s3://valyn-pulumi-state && pulumi up",
        "destroy": "cd aws && pulumi login s3://valyn-pulumi-state && pulumi down",
        "clean": "rm -rf .next/ .open-next/ node_modules/ bun.lockb tsconfig.tsbuildinfo next-env.d.ts"
    },
    "dependencies": {
        "@aws-sdk/client-dynamodb": "^3.994.0",
        "@aws-sdk/client-s3": "^3.1037.0",
        "@aws-sdk/lib-dynamodb": "^3.994.0",
        "@hookform/resolvers": "^5.2.2",
        "@prisma/adapter-pg": "^7.4.1",
        "@prisma/client": "^7.4.1",
        "@react-email/components": "^1.0.8",
        "@shopify/app-bridge-react": "^4.2.10",
        "@shopify/polaris": "^13.9.5",
        "@shopify/shopify-api": "^13.0.0",
        "@t3-oss/env-nextjs": "^0.13.11",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "axios": "^1.13.5",
        "caniuse-lite": "^1.0.30001770",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "mailparser": "^3.7.4",
        "next": "^16.2.4",
        "nodemailer": "^7.0.9",
        "pg": "^8.18.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-hook-form": "^7.71.1",
        "react-hot-toast": "^2.6.0",
        "tailwind-merge": "^3.5.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3",
        "@pulumi/aws": "^7.24.0",
        "@pulumi/pulumi": "^3.223.0",
        "@pulumi/random": "^4.19.1",
        "@react-email/preview": "^0.0.14",
        "@react-email/preview-server": "5.1.0",
        "@tailwindcss/postcss": "^4.2.0",
        "@types/mailparser": "^3.4.6",
        "@types/node": "^20.19.33",
        "@types/nodemailer": "^7.0.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript-eslint/eslint-plugin": "^8.56.0",
        "@typescript-eslint/parser": "^8.56.0",
        "daisyui": "^5.5.19",
        "eslint": "^9",
        "eslint-config-next": "15.3.8",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.3",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "prisma": "^7.4.1",
        "react-email": "5.0.5",
        "tailwindcss": "^4.2.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "vitest": "^4.1.5"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{json,md,mdx,yml,yaml,css}": [
            "prettier --write"
        ]
    }
}
