generator client {
    provider   = "prisma-client"
    output     = "../src/generated/prisma"
    engineType = "client"
}

datasource db {
    provider = "postgresql"
}

enum Intent {
    WISMO
    OTHER
}

enum EmailStatus {
    PENDING
    REPLIED
    FAILED
    IGNORED
    REVIEW
    LIMIT_EXCEEDED
    MISCLASSIFIED
}

enum Tone {
    NEUTRAL
    FRIENDLY
    FORMAL
}

enum Strictness {
    AUTO_REPLY
    REVIEW_QUEUE
    PASS_THROUGH
}

enum FallbackBehavior {
    SEND_FALLBACK
    QUEUE_REVIEW
    SKIP
}

enum TemplateType {
    IN_TRANSIT
    PROCESSING
    NO_ORDER
    MULTIPLE
}

enum SubscriptionStatus {
    PENDING
    ACTIVE
    CANCELLED
    DECLINED
    EXPIRED
    FROZEN
}

model Shop {
    id            String    @id @default(uuid())
    shopDomain    String    @unique
    accessToken   String
    scopes        String
    installedAt   DateTime  @default(now())
    uninstalledAt DateTime?
    createdAt     DateTime  @default(now())
    updatedAt     DateTime  @updatedAt

    subscriptionId     String?
    subscriptionStatus SubscriptionStatus?
    planKey            String?
    trialEndsOn        DateTime?
    currentPeriodEnd   DateTime?

    settings  Settings?
    emailLogs EmailLog[]
    templates ReplyTemplate[]
}

model Settings {
    id                   String  @id @default(uuid())
    shopId               String  @unique
    autoReplyEnabled     Boolean @default(true)
    responseDelaySeconds Int     @default(0)
    language             String  @default("en")
    greeting             String  @default("Hello,")
    signature            String  @default("Thank you for your patience.")
    tone                 Tone    @default(NEUTRAL)
    supportEmail         String?

    strictness       Strictness       @default(AUTO_REPLY)
    fallbackBehavior FallbackBehavior @default(SEND_FALLBACK)

    smtpHost           String?
    smtpPort           Int?
    smtpSecure         Boolean   @default(true)
    smtpUser           String?
    smtpPassEnc        String?
    smtpFromName       String?
    smtpFromAddress    String?
    smtpLastVerifiedAt DateTime?
    smtpLastError      String?

    inboundAddress String? @unique

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model ReplyTemplate {
    id        String       @id @default(uuid())
    shopId    String
    type      TemplateType
    name      String
    body      String
    isDefault Boolean      @default(false)
    createdAt DateTime     @default(now())
    updatedAt DateTime     @updatedAt
    shop      Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)

    @@unique([shopId, type, name])
    @@index([shopId, type])
}

model EmailLog {
    id               String      @id @default(uuid())
    shopId           String
    inboundMessageId String?     @unique
    senderEmail      String
    subject          String
    body             String
    intent           Intent
    detectedLanguage String?
    confidence       Float?
    detectionReason  String?

    orderId   String?
    orderName String?

    status        EmailStatus @default(PENDING)
    errorMessage  String?
    replyPreview  String?
    repliedAt     DateTime?
    receivedAt    DateTime    @default(now())
    retryCount    Int         @default(0)
    lastRetryAt   DateTime?
    reviewedAt    DateTime?
    reviewedBy    String?
    manuallyMarked Boolean    @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

    @@index([shopId, receivedAt])
    @@index([shopId, status])
    @@index([shopId, intent, status])
}
